#!/usr/bin/env bash
# .githooks/pre-commit
# Runs before each git commit.
# Validates memory-bank/*.md files (schema, links, session limits, privacy).
# Intentionally uses --scope memory so that README/docs drift never blocks
# a valid memory-bank commit. Full repo-docs validation runs in CI.
#
# Setup (auto via `init.sh` inside a git repo):
#   git config core.hooksPath .githooks
#
# Manual setup:
#   chmod +x .githooks/pre-commit
#   git config core.hooksPath .githooks

set -eo pipefail

# ── Check if there are staged changes in memory-bank/ ─────────────────────────
CHANGED_MB=$(git diff --cached --name-only 2>/dev/null | grep "^memory-bank/" | grep "\.md$" | head -1)

if [ -z "$CHANGED_MB" ]; then
  exit 0
fi

# ── Require node ──────────────────────────────────────────────────────────────
if ! command -v node &>/dev/null; then
  echo "⚠  pre-commit: node not found — skipping memora validate"
  exit 0
fi

# ── Run memory-scope validation ────────────────────────────────────────────────
echo ""
echo "🔍  memora validate --scope memory ..."
echo ""

if node bin/memora.js validate --scope memory 2>&1; then
  echo ""
  echo "✓   memory-bank files are valid."
  echo ""
else
  echo ""
  echo "✗   Validation failed. Fix the errors above before committing."
  echo "    Run:  node bin/memora.js validate --scope memory"
  echo "    Tip:  node bin/memora.js validate --scope memory --watch  for live feedback"
  echo "    Note: README/docs checks run in CI (--scope repo-docs)."
  echo ""
  exit 1
fi

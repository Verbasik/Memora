{
  "permissions": {
    "allow": [
      "Bash(wc -l memory-bank/*.md)",
      "Bash(du -sh memory-bank .claude .codex .qwen .opencode docs 2>/dev/null)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(*.p12)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null)}\"; [ -n \"$ROOT\" ] && bash \"$ROOT/memory-bank/scripts/check-save-trigger.sh\" || true'",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null)}\"; [ -n \"$ROOT\" ] && bash \"$ROOT/memory-bank/scripts/check-reflect-trigger.sh\" || true'"
          },
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null)}\"; [ -n \"$ROOT\" ] && bash \"$ROOT/memory-bank/scripts/check-consolidate-trigger.sh\" || true'"
          },
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null)}\"; [ -n \"$ROOT\" ] && bash \"$ROOT/memory-bank/scripts/check-gc-trigger.sh\" || true'"
          }
        ]
      }
    ]
  }
}

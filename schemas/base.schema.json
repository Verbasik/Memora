{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memora.dev/schemas/base.schema.json",
  "title": "Memora Base Card",
  "description": "Shared definitions for all Memora memory-bank cards",
  "type": "object",
  "required": ["title", "authority", "status"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable card title"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique slug identifier for this card"
    },
    "type": {
      "type": "string",
      "enum": [
        "PROJECT", "ARCHITECTURE", "CONSTITUTION", "CONVENTIONS", "TESTING",
        "DECISIONS", "CHANGELOG", "OPEN_QUESTIONS", "LIFECYCLE", "INDEX",
        "ADR", "AREA", "PATTERN",
        "FACT", "EPISODE", "POLICY", "AGENT", "TEST"
      ],
      "description": "Card type"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this card record"
    },
    "authority": {
      "type": "string",
      "enum": ["controlled", "immutable", "free"],
      "description": "Write protection level"
    },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"],
      "description": "Card lifecycle status"
    },
    "pii_risk": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"],
      "default": "none",
      "description": "Personal identifiable information risk level"
    },
    "ttl": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "description": "ISO date (YYYY-MM-DD) or duration (e.g. 90d)" }
      ],
      "description": "Time-to-live. null = permanent"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Labels for filtering and discovery"
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date when this card was last verified as accurate"
    },
    "purpose": {
      "type": "string",
      "description": "One-line description of what this card contains"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memora.dev/schemas/agent.schema.json",
  "title": "Memora AGENT Card",
  "description": "Schema for AGENTS/*.md — AI agent profiles: role, capabilities and constraints",
  "type": "object",
  "required": ["title", "id", "type", "version", "authority", "status", "owner", "created_at", "pii_risk"],
  "properties": {
    "title":      { "type": "string", "minLength": 1 },
    "id":         { "type": "string" },
    "type":       { "type": "string", "const": "AGENT" },
    "version":    { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authority":  { "type": "string", "enum": ["controlled", "free"] },
    "status":     { "type": "string", "enum": ["active", "draft", "deprecated"] },
    "owner":      { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "pii_risk":   {
      "type": "string",
      "enum": ["none", "low", "medium", "high"],
      "description": "Agent profiles may contain role/identity info — default low"
    },
    "ttl":        { "oneOf": [{ "type": "null" }, { "type": "string" }] },
    "tags":       { "type": "array", "items": { "type": "string" } },
    "last_verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "profile": {
      "type": "string",
      "enum": ["full-stack-dev", "code-reviewer", "architect", "debugger", "writer", "custom"],
      "description": "Agent profile preset. See PATTERNS/agent-profiles.md"
    },
    "observation_types": {
      "type": "array",
      "items": { "type": "string", "enum": ["bugfix", "feature", "refactor", "discovery", "decision", "incident"] },
      "description": "Override observation types for this agent"
    },
    "observation_concepts": {
      "type": "array",
      "items": { "type": "string", "enum": ["how-it-works", "why-it-exists", "what-changed", "problem-solution", "gotcha", "pattern", "trade-off"] },
      "description": "Override observation concepts for this agent"
    },
    "restore_layers": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1, "maximum": 6 },
      "description": "Which progressive disclosure layers to load on restore. See PATTERNS/progressive-disclosure.md"
    },
    "token_budget": {
      "type": "integer",
      "minimum": 1000,
      "description": "Max token budget for context restore (~1 token per 4 chars). Default: 8000"
    }
  },
  "additionalProperties": true
}

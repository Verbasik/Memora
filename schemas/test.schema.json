{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memora.dev/schemas/test.schema.json",
  "title": "Memora TEST Card",
  "description": "Schema for TESTS/*.md — documented test cases with expected/actual results",
  "type": "object",
  "required": ["title", "id", "type", "version", "authority", "status", "owner", "created_at", "pii_risk"],
  "properties": {
    "title":        { "type": "string", "minLength": 1 },
    "id":           { "type": "string" },
    "type":         { "type": "string", "const": "TEST" },
    "version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authority":    { "type": "string", "enum": ["controlled", "free"] },
    "status":       { "type": "string", "enum": ["active", "draft", "deprecated"] },
    "owner":        { "type": "string", "minLength": 1 },
    "created_at":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updated_at":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "related_fact": { "type": "string", "description": "ID of the FACT card this test verifies" },
    "pii_risk":     { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "ttl":          { "oneOf": [{ "type": "null" }, { "type": "string" }] },
    "tags":         { "type": "array", "items": { "type": "string" } },
    "test_status":  {
      "type": "string",
      "enum": ["pending", "pass", "fail", "skip", "error"],
      "description": "Last test execution result"
    },
    "last_verified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memora.dev/schemas/project.schema.json",
  "title": "Memora PROJECT Card",
  "description": "Schema for PROJECT.md — project identity, mission, scope and domain vocabulary",
  "type": "object",
  "required": ["title", "id", "type", "version", "authority", "status", "pii_risk"],
  "properties": {
    "title":          { "type": "string", "minLength": 1 },
    "id":             { "type": "string" },
    "type":           { "type": "string", "const": "PROJECT" },
    "version":        { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authority":      { "type": "string", "enum": ["controlled", "immutable", "free"] },
    "status":         { "type": "string", "enum": ["active", "draft", "deprecated"] },
    "pii_risk":       { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "ttl":            { "oneOf": [{ "type": "null" }, { "type": "string" }] },
    "tags":           { "type": "array", "items": { "type": "string" } },
    "purpose":        { "type": "string" },
    "canonical_owner":{ "type": "string" },
    "last_verified":  { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "max_lines":      { "type": "integer", "minimum": 1 },
    "depends_on":     { "type": "array", "items": { "type": "string" } },
    "provides":       { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

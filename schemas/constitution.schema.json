{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://memora.dev/schemas/constitution.schema.json",
  "title": "Memora CONSTITUTION Card",
  "description": "Schema for CONSTITUTION.md — inviolable project principles and governance rules",
  "type": "object",
  "required": ["title", "id", "type", "version", "authority", "status", "pii_risk"],
  "properties": {
    "title":          { "type": "string", "minLength": 1 },
    "id":             { "type": "string" },
    "type":           { "type": "string", "const": "CONSTITUTION" },
    "version":        { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authority":      { "type": "string", "const": "immutable",
                        "description": "CONSTITUTION cards MUST be immutable" },
    "status":         { "type": "string", "enum": ["active", "deprecated"] },
    "pii_risk":       { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "ttl":            { "oneOf": [{ "type": "null" }, { "type": "string" }] },
    "tags":           { "type": "array", "items": { "type": "string" } },
    "purpose":        { "type": "string" },
    "last_verified":  { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}
